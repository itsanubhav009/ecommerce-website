# ---------------------------------------------------------------------------
# Spider Threads environment variables
# Copy this file to ".env.local" for local dev, and set the same three values
# in Vercel under: Project -> Settings -> Environment Variables.
# ---------------------------------------------------------------------------

# Supabase project URL.  Supabase Dashboard -> Project Settings -> API -> "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Supabase SERVICE ROLE key (secret!).  Same API page -> "service_role" key.
# This is server-only. NEVER expose it to the browser / never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to sign login cookies. Use a long random string in production,
# e.g. run:  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string
